{
  "name": "@deebeetech/sqleasy",
  "version": "13.0.0",
  "description": "Lightweight SQL builder and parser for MSSQL, MySQL, Postgres, and SQLite.",
  "keywords": [
    "sql",
    "sql-builder",
    "query-builder",
    "sql-query-builder",
    "postgres",
    "postgresql",
    "mysql",
    "mssql",
    "sqlite",
    "prepared-statements",
    "typescript",
    "database"
  ],
  "homepage": "https://github.com/deebee-tech/sqleasy",
  "license": "MIT",
  "author": {
    "name": "Sandy Weatherby",
    "email": "unicornbeachdiaries@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/deebee-tech/sqleasy"
  },
  "type": "module",
  "main": "dist/index.cjs",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "types": "dist/index.d.mts",
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false
}
