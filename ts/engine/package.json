{
  "name": "@deebeetech/sqleasy-engine",
  "version": "1.2.0",
  "description": "A thin, opt-in executor for @deebeetech/sqleasy: runs its prepared SQL and transactions on Postgres, MySQL, SQL Server, and SQLite \u2014 loading only the driver you import.",
  "keywords": [
    "sql",
    "sql-executor",
    "query-runner",
    "postgres",
    "mysql",
    "mssql",
    "sqlite",
    "libsql",
    "transactions",
    "sqleasy",
    "typescript",
    "database"
  ],
  "homepage": "https://github.com/deebee-tech/sqleasy",
  "license": "MIT",
  "private": false,
  "author": {
    "name": "Sandy Weatherby",
    "email": "unicornbeachdiaries@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/deebee-tech/sqleasy",
    "directory": "ts/engine"
  },
  "type": "module",
  "main": "dist/index.cjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./sqlite": {
      "import": {
        "types": "./dist/sqlite/index.d.mts",
        "default": "./dist/sqlite/index.mjs"
      },
      "require": {
        "types": "./dist/sqlite/index.d.cts",
        "default": "./dist/sqlite/index.cjs"
      }
    },
    "./postgres": {
      "import": {
        "types": "./dist/postgres/index.d.mts",
        "default": "./dist/postgres/index.mjs"
      },
      "require": {
        "types": "./dist/postgres/index.d.cts",
        "default": "./dist/postgres/index.cjs"
      }
    },
    "./mysql": {
      "import": {
        "types": "./dist/mysql/index.d.mts",
        "default": "./dist/mysql/index.mjs"
      },
      "require": {
        "types": "./dist/mysql/index.d.cts",
        "default": "./dist/mysql/index.cjs"
      }
    },
    "./mssql": {
      "import": {
        "types": "./dist/mssql/index.d.mts",
        "default": "./dist/mssql/index.mjs"
      },
      "require": {
        "types": "./dist/mssql/index.d.cts",
        "default": "./dist/mssql/index.cjs"
      }
    },
    "./introspection": {
      "import": {
        "types": "./dist/introspection/index.d.mts",
        "default": "./dist/introspection/index.mjs"
      },
      "require": {
        "types": "./dist/introspection/index.d.cts",
        "default": "./dist/introspection/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "test": "vitest run --exclude \"test/conformance/**\"",
    "conformance:integration": "vitest run test/conformance",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "peerDependencies": {
    "@libsql/client": ">=0.14.0",
    "mssql": ">=10.0.0",
    "mysql2": ">=3.0.0",
    "pg": ">=8.0.0"
  },
  "peerDependenciesMeta": {
    "@libsql/client": {
      "optional": true
    },
    "mssql": {
      "optional": true
    },
    "pg": {
      "optional": true
    },
    "mysql2": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "catalog:",
    "@libsql/client": "catalog:",
    "@sebbo2002/semantic-release-jsr": "catalog:",
    "@semantic-release/changelog": "catalog:",
    "@semantic-release/commit-analyzer": "catalog:",
    "@semantic-release/git": "catalog:",
    "@semantic-release/github": "catalog:",
    "@semantic-release/npm": "catalog:",
    "@semantic-release/release-notes-generator": "catalog:",
    "@sqleasy/eslint-config": "workspace:*",
    "@sqleasy/tsconfig": "workspace:*",
    "@types/mssql": "catalog:",
    "@types/node": "catalog:",
    "@types/pg": "catalog:",
    "conventional-changelog-conventionalcommits": "catalog:",
    "eslint": "catalog:",
    "eslint-config-prettier": "catalog:",
    "mssql": "catalog:",
    "mysql2": "catalog:",
    "pg": "catalog:",
    "prettier": "catalog:",
    "semantic-release": "catalog:",
    "semantic-release-replace-plugin": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vitest": "catalog:"
  }
}
