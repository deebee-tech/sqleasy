{
  "name": "sqleasy-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Polyglot, contract-first monorepo for SQLEasy — the query builder and execution engine across TypeScript, Dart, Python, C#, and Go, held to one another by a shared golden contract.",
  "license": "MIT",
  "author": {
    "name": "Sandy Weatherby",
    "email": "unicornbeachdiaries@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/deebee-tech/sqleasy"
  },
  "type": "module",
  "packageManager": "pnpm@11.13.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "check": "turbo run typecheck && pnpm check:deps && pnpm check:parity",
    "check:deps": "node scripts/check-deps.mjs",
    "check:parity": "node scripts/check-dialect-parity.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "spell": "cspell --no-progress \"**\"",
    "goldens": "turbo run goldens",
    "harness:up": "docker compose -f docker-compose.harness.yml up -d --wait",
    "harness:down": "docker compose -f docker-compose.harness.yml down -v"
  },
  "devDependencies": {
    "cspell": "catalog:",
    "prettier": "catalog:",
    "turbo": "catalog:"
  }
}
