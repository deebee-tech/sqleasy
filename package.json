{
  "name": "@deebeetech/sqleasy",
  "version": "4.0.0",
  "description": "Lightweight SQL builder and parser for MSSQL, MySQL, Postgres, and SQLite.",
  "keywords": [
    "sql",
    "sql-builder",
    "query-builder",
    "sql-query-builder",
    "postgres",
    "postgresql",
    "mysql",
    "mssql",
    "sqlite",
    "prepared-statements",
    "typescript",
    "database"
  ],
  "homepage": "https://github.com/deebee-tech/sqleasy",
  "license": "MIT",
  "private": false,
  "author": {
    "name": "Sandy Weatherby",
    "email": "unicornbeachdiaries@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/deebee-tech/sqleasy"
  },
  "type": "module",
  "main": "dist/index.mjs",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "types": "dist/index.d.mts",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown && cpy './package.json' './dist/' && cpy './README.md' './dist/' && cpy './CHANGELOG.md' './dist/' && cpy './LICENSE' './dist/'",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "goldens": "GOLDENS_WRITE=1 vitest run tests/conformance",
    "lint": "eslint .",
    "spell": "cspell --no-progress \"**\"",
    "test": "vitest --coverage",
    "typecheck": "tsc --noEmit"
  },
  "packageManager": "pnpm@11.13.0",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@sebbo2002/semantic-release-jsr": "^4.0.2",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.9",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "conventional-changelog-conventionalcommits": "^10.2.1",
    "cpy-cli": "^7.0.0",
    "cspell": "^10.0.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.9.5",
    "semantic-release": "^25.0.7",
    "semantic-release-replace-plugin": "^1.2.7",
    "tsdown": "^0.22.7",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  }
}
